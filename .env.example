PORT=3000
# PostgreSQL connection string (for local dev)
DATABASE_URL=postgresql://localhost:5432/dpoker
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_RUN_OPENSSL_RAND_HEX_32_THIS_VALUE_IS_NOT_SECURE
JWT_EXPIRES_IN=30d
NODE_ENV=development
# On BTP CF, VCAP_SERVICES is auto-injected — no need to set DATABASE_URL
